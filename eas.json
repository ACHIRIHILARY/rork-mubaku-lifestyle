{
  "cli": {
    "version": ">= 16.28.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_USE_BUN": "0",
        "NPM_FLAGS": "--legacy-peer-deps"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_USE_BUN": "0",
        "NPM_FLAGS": "--legacy-peer-deps"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_USE_BUN": "0",
        "NPM_FLAGS": "--legacy-peer-deps"
      }
    }
  }
}